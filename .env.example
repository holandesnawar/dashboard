# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno del panel Holandés Nawar.
# Copia este archivo a .env.local para desarrollo, y configura las MISMAS
# variables en Vercel (Project → Settings → Environment Variables).
# NUNCA subas los valores reales al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Login del panel ──────────────────────────────────────────────────────────
# Contraseña de admin (tú + director académico). Elige una fuerte.
DASHBOARD_PASSWORD=

# Secreto aleatorio para firmar la cookie de sesión (≥32 caracteres).
# Genera uno con:  openssl rand -hex 32
DASHBOARD_SESSION_SECRET=

# ── Leads (systeme.io) ───────────────────────────────────────────────────────
# La misma API key que usa nawar-web (X-API-Key de systeme.io).
SYSTEME_API_KEY=

# ── Academia (LearnHouse) ────────────────────────────────────────────────────
# Base de la API de la academia (sin barra final).
LEARNHOUSE_API_BASE=https://academia.holandesnawar.nl
# Clave compartida con el backend. DEBE ser idéntica a LEARNHOUSE_DASHBOARD_API_KEY
# configurada en Railway (servicio learnhouse). Genera con: openssl rand -hex 32
LEARNHOUSE_DASHBOARD_API_KEY=

# ── Embebido en Nextcloud ────────────────────────────────────────────────────
# Origen de tu Nextcloud, para permitir el iframe (sin barra final).
# Ej: https://cloud.holandesnawar.com
NEXTCLOUD_ORIGIN=
